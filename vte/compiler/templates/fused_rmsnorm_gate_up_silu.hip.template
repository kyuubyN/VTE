#include <hip/hip_runtime.h>
#include <hip/hip_fp16.h>

// Fusão do FFN (parte 1/2): Gate_Proj + Up_Proj + SwiGLU em um único kernel.
//
// O RMSNorm continua como um kernel SEPARADO (rmsnorm_kernel, já otimizado
// com LDS/uint4) — ao contrário da fusão QKV (onde recalcular RMSNorm em
// ~16 blocos era desprezível), aqui o grid tem ~35 blocos (intermediate_size
// 8960 / 256), e recalcular a redução (com suas ~8 barreiras __syncthreads
// de árvore) 35x se mostrou MAIS CARO do que os round-trips de VRAM que a
// fusão economizava — medido empiricamente (regressão de 19.3 para 13.5
// tok/s ao tentar fundir também o RMSNorm aqui). Então fundimos só o que
// realmente compensa: Gate e Up no mesmo laço de threads (reaproveitando
// X_norm da LDS uma vez só) + SiLU em registrador, cortando de 3 kernels
// (gate_proj, up_proj, swiglu) para 1.
//
// Down_proj continua separado (matmul_kernel já otimizado com LDS).
// Sem bias no Qwen2.5 para gate_proj/up_proj (confirmado no GGUF).
//
// Suporte a batch (experimento Fase M, batch>1): blockIdx.y = batch_idx,
// mesmo padrão de gemv_coalesced_kernel. x_norm/output indexados por
// batch_idx * stride; gate_weight/up_weight são compartilhados entre todas
// as sequências do batch (mesmo peso, lido uma vez por bloco via LDS).
// batch=1 (grid.y=1) reduz exatamente ao comportamento original.

#define FUSED_FFN_MAX_HIDDEN 1536

extern "C" __global__ void fused_gate_up_silu_kernel(
    const __half* __restrict__ x_norm,        // [batch, hidden_size] — já normalizado (RMSNorm em kernel separado)
    const __half* __restrict__ gate_weight,   // [intermediate_size, hidden_size]
    const __half* __restrict__ up_weight,     // [intermediate_size, hidden_size]
    __half* __restrict__ output,              // [batch, intermediate_size] — SiLU(gate) * up
    int hidden_size,
    int intermediate_size
) {
    __shared__ __half x_sh[FUSED_FFN_MAX_HIDDEN];

    int tid = threadIdx.x;
    int n = blockIdx.x * blockDim.x + tid;
    int batch_idx = blockIdx.y;

    const __half* x_norm_row = x_norm + (size_t)batch_idx * hidden_size;
    __half* output_row = output + (size_t)batch_idx * intermediate_size;

    // Carrega x_norm cooperativamente na LDS uma única vez por bloco —
    // reaproveitado tanto para o dot product do Gate quanto do Up.
    for (int i = tid; i < hidden_size; i += blockDim.x) {
        x_sh[i] = x_norm_row[i];
    }
    __syncthreads();

    if (n >= intermediate_size) return;

    const __half* gate_row = gate_weight + (size_t)n * hidden_size;
    const __half* up_row = up_weight + (size_t)n * hidden_size;

    float gate_sum = 0.0f;
    float up_sum = 0.0f;
    for (int k = 0; k < hidden_size; k++) {
        float xn = __half2float(x_sh[k]);
        gate_sum += xn * __half2float(gate_row[k]);
        up_sum += xn * __half2float(up_row[k]);
    }

    float sigmoid = 1.0f / (1.0f + __expf(-gate_sum));
    float silu = gate_sum * sigmoid;
    float result = silu * up_sum;

    output_row[n] = __float2half(result);
}
