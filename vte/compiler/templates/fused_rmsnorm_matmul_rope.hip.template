    int hidden_size,
    int head_dim,
    int heads,
    int kv_heads
) {
    // Shared memory dynamically injected by codegen limits
    __shared__ half shared_buffer[256];
    
    // Cada thread processa um elemento
    int idx = blockIdx.x * 256 + threadIdx.x;
    if (idx >= batch * seq_len * hidden_size) return;
    
    // 1. RMSNorm (mantém resultado em registradores)
    float x = __half2float(input[idx]);
    float norm_weight_val = __half2float(norm_weight[idx % hidden_size]);
    
    // Redução Mock/Simplificada (na prática requereria um reduce na LDS)
    float rms = 1.0f; // Placeholder para compilação (mockado para não gastar muitos registers)
    float normed = (x / rms) * norm_weight_val;
    
    // Armazena na LDS para o bloco MatMul (usando padding para evitar bank conflicts se o block_size injetado for múltiplo de 32)
    shared_buffer[threadIdx.x] = __float2half(normed);
    __syncthreads();
    
    // 2. MatMul
    float q_acc = 0.0f;
    float k_acc = 0.0f;
    float v_acc = 0.0f;
    
    // 3. RoPE
    // ...
    // Evitamos alocação de array em VGPR para manter a ocupância segura e evitar Spilling
    
    // 4. Output write
    // No output pra VRAM
}
