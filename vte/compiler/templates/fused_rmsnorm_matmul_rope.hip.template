extern "C" __global__ void fused_rmsnorm_matmul_rope_kernel(
    const half* __restrict__ input,           // [batch, seq_len, hidden_size]
    const half* __restrict__ norm_weight,     // [hidden_size]
    const half* __restrict__ qkv_weight,      // [hidden_size, 3 * hidden_size]
    const half* __restrict__ cos_cache,       // [max_seq, head_dim]
    const half* __restrict__ sin_cache,       // [max_seq, head_dim]
    half* __restrict__ output_q,              // [batch, seq_len, heads, head_dim]
