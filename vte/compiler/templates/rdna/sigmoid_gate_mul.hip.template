#include <hip/hip_runtime.h>
#include <hip/hip_fp16.h>

// Qwen3.5 full_attention: attn_output = attn_out * sigmoid(gate), onde
// `gate` é a segunda metade (por-head, intercalada) da saída crua do
// q_proj -- ver Qwen3_5Attention.forward (modeling_qwen3_5.py):
//   query_states, gate = torch.chunk(q_proj(x).view(..., head_dim*2), 2, dim=-1)
//   ...
//   attn_output = attn_output * torch.sigmoid(gate)
//
// `gate_stride`/`gate_offset` leem direto do buffer intercalado do
// q_proj (largura head_dim*2 por head) sem precisar de um buffer
// separado só pro gate -- extraído uma única vez, aqui, no momento exato
// em que é usado.

extern "C" __global__ void sigmoid_gate_mul_kernel(
    const __half* __restrict__ attn_out,   // [num_heads, head_dim] contíguo
    const __half* __restrict__ q_proj_raw, // [num_heads, head_dim*2] (buffer bruto do q_proj)
    __half* __restrict__ output,           // [num_heads, head_dim] contíguo
    int num_heads,
    int head_dim,
    int gate_stride,
    int gate_offset
) {
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    int total = num_heads * head_dim;
    if (idx >= total) return;

    int head = idx / head_dim;
    int d = idx % head_dim;

    float a = __half2float(attn_out[idx]);
    float g = __half2float(q_proj_raw[(size_t)head * gate_stride + gate_offset + d]);
    float sig = 1.0f / (1.0f + expf(-g));
    output[idx] = __float2half(a * sig);
}
